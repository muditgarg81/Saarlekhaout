// prisma/schema/purchase.prisma
//
// Trimmed to the ERP / Tally bridge that the Sales & Dispatch debtor sync hangs
// off. All procurement models (vendor, PR, RFQ, PO, supplier invoice, payments,
// creditor bridge) were removed when this became a sales-only project. The
// debtor-side maps/statements live in the `sales` schema and relate to
// ErpConnection here.

enum ErpType {
  TALLY
  BUSY
  MARG
  ZOHO_BOOKS
  SAP_B1
  CUSTOM

  @@schema("purchase")
}

enum ErpConnStatus {
  ACTIVE
  PAUSED
  AGENT_OFFLINE
  ERROR

  @@schema("purchase")
}

enum ErpSyncDirection {
  PULL
  PUSH

  @@schema("purchase")
}

enum ErpSyncStatus {
  OK
  PARTIAL
  FAILED

  @@schema("purchase")
}

enum WritebackStatus {
  PENDING
  APPROVED
  POSTED
  FAILED
  SKIPPED

  @@schema("purchase")
}

model ErpConnection {
  id               String        @id @default(cuid())
  companyId        String
  type             ErpType       @default(TALLY)
  erpCompanyName   String // SVCurrentCompany for Tally
  writebackEnabled Boolean       @default(false)
  status           ErpConnStatus @default(AGENT_OFFLINE)
  lastSyncAt       DateTime?
  config           Json? // host hints, schedule, format, tdl collection name
  createdAt        DateTime      @default(now())

  agents           BridgeAgent[]
  customerMaps     CustomerErpMap[] // debtor-side ledger maps (sales schema)
  debtorStatements DebtorStatement[] // debtor outstandings pulled by the bridge
  syncLogs         ErpSyncLog[]
  writebacks       ErpWriteback[]

  @@unique([companyId, type, erpCompanyName])
  @@index([companyId, status])
  @@schema("purchase")
}

model BridgeAgent {
  id           String        @id @default(cuid())
  companyId    String
  connectionId String
  name         String
  tokenHash    String // hashed, rotatable; never store plaintext
  lastSeenAt   DateTime?
  version      String?
  connection   ErpConnection @relation(fields: [connectionId], references: [id])

  @@index([companyId, connectionId])
  @@schema("purchase")
}

model ErpSyncLog {
  id           String           @id @default(cuid())
  companyId    String
  connectionId String
  direction    ErpSyncDirection
  report       String? // "GroupOutstandings" | "LedgerOutstandings" | "BillsReceivable" | ...
  status       ErpSyncStatus
  message      String?
  recordCount  Int?
  createdAt    DateTime         @default(now())
  connection   ErpConnection    @relation(fields: [connectionId], references: [id])

  @@index([companyId, connectionId, createdAt])
  @@schema("purchase")
}

model ErpWriteback {
  id             String          @id @default(cuid())
  companyId      String
  connectionId   String
  voucherId      String // Saarlekha ReceiptVoucher.id
  idempotencyKey String // dedupe; one ERP voucher per receipt
  status         WritebackStatus @default(PENDING)
  erpVoucherId   String? // returned Tally voucher id once posted
  approvedById   String?
  message        String?
  createdAt      DateTime        @default(now())
  connection     ErpConnection   @relation(fields: [connectionId], references: [id])

  @@unique([companyId, idempotencyKey])
  @@index([companyId, status])
  @@schema("purchase")
}
