// prisma/schema/stores.prisma
//
// Trimmed to the inventory backbone the Sales & Dispatch app depends on:
// the Product/Item master, warehouses (Store/Bin), batches, and the append-only
// StockLedger that dispatch issues stock out of. All procurement/inwards/QC
// models (indent, GRN, inspection, issue, gate pass, reorder) were removed when
// this became a sales-only project.

enum ItemType {
  RAW_MATERIAL
  CONSUMABLE
  SPARE
  TOOL
  PACKING
  SEMI_FINISHED
  FINISHED_GOOD

  @@schema("stores")
}

enum ValuationMethod {
  WEIGHTED_AVG
  FIFO

  @@schema("stores")
}

enum AbcClass {
  A
  B
  C
  NONE

  @@schema("stores")
}

enum MasterStatus {
  ACTIVE
  INACTIVE

  @@schema("stores")
}

enum LedgerTxnType {
  OPENING
  GRN_RECEIPT
  ISSUE
  RETURN_TO_STORE
  RETURN_TO_VENDOR
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  SCRAP_OUT

  @@schema("stores")
}

model ItemCategory {
  id        String         @id @default(cuid())
  companyId String
  code      String
  name      String
  parentId  String?
  parent    ItemCategory?  @relation("CatTree", fields: [parentId], references: [id])
  children  ItemCategory[] @relation("CatTree")

  @@unique([companyId, code])
  @@schema("stores")
}

model ItemCodeScheme {
  id        String @id @default(cuid())
  companyId String @unique
  segments  Json
  separator String @default("-")

  @@schema("stores")
}

model Item {
  id            String          @id @default(cuid())
  companyId     String
  code          String // generated from scheme, override allowed
  name          String
  description   String?
  categoryId    String?
  departmentId  String?
  type          ItemType
  baseUom       String
  altUom        String?
  altUomFactor  Float? // 1 altUom = factor * baseUom
  make          String?
  specification String?
  hsnCode       String?
  gstRate       Float?
  reorderLevel  Float           @default(0)
  minStock      Float           @default(0)
  maxStock      Float           @default(0)
  leadTimeDays  Int             @default(0)
  shelfLifeDays Int? // null = no expiry tracking
  qcRequired    Boolean         @default(false)
  valuation     ValuationMethod @default(WEIGHTED_AVG)
  abcClass      AbcClass        @default(NONE)
  status        MasterStatus    @default(ACTIVE)
  deletedAt     DateTime?
  moq           Float           @default(1)
  company       Company         @relation(fields: [companyId], references: [id])
  department    Department?     @relation(fields: [departmentId], references: [id])

  ledger StockLedger[]

  @@unique([companyId, code])
  @@index([companyId, categoryId])
  @@index([companyId, departmentId])
  @@schema("stores")
}

model Store {
  id        String       @id @default(cuid())
  companyId String
  code      String
  name      String
  status    MasterStatus @default(ACTIVE)
  company   Company      @relation(fields: [companyId], references: [id])
  bins      Bin[]

  @@unique([companyId, code])
  @@schema("stores")
}

model Bin {
  id      String @id @default(cuid())
  storeId String
  code    String
  store   Store  @relation(fields: [storeId], references: [id])

  @@unique([storeId, code])
  @@schema("stores")
}

model Batch {
  id         String    @id @default(cuid())
  companyId  String
  itemId     String
  lotNo      String
  mfgDate    DateTime?
  expiryDate DateTime?

  @@unique([companyId, itemId, lotNo])
  @@index([companyId, expiryDate])
  @@schema("stores")
}

model StockLedger {
  id          String        @id @default(cuid())
  companyId   String
  itemId      String
  storeId     String
  binId       String?
  batchId     String?
  txnType     LedgerTxnType
  qty         Float // signed, in base UOM
  rate        Float? // unit cost for valuation
  refType     String? // DISPATCH | OPENING | ADJUSTMENT | ...
  refId       String?
  createdById String
  createdAt   DateTime      @default(now())
  item        Item          @relation(fields: [itemId], references: [id])

  @@index([companyId, itemId, storeId])
  @@index([companyId, refType, refId])
  @@schema("stores")
}
